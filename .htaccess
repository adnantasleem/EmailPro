<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect everything to public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block sensitive files
<FilesMatch "^\.env|\.env\..+|composer\.(json|lock)|package(-lock)?\.json|webpack\.mix\.js|artisan$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block sensitive directories
<IfModule mod_rewrite.c>
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|node_modules)/ - [F,L]
</IfModule>

# Disable directory listing
Options -Indexes
